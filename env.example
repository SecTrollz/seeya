# eSIM Proxy Server Configuration
# Copy to /etc/esim-proxy/env or set via environment

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Backend service URL (the actual service to proxy requests to)
BACKEND_URL=https://api.internal.example.com

# ============================================
# API KEY CONFIGURATION (choose one)
# ============================================

# Option 1: Inline comma-separated keys (for small deployments)
# API_KEYS=key-prod-1,key-prod-2,key-prod-3

# Option 2: File-based keys (for large key rotations)
# Place keys one per line in the file, then set:
# API_KEY_FILE=/etc/esim-proxy/keys.txt

# Default: API_KEYS is used if both are set; API_KEY_FILE is tried if API_KEYS is empty

# ============================================
# SERVER CONFIGURATION
# ============================================

# Listen port for the proxy (default: 8080)
PORT=8080

# Rate limit per API key, per minute (default: 100)
# Set to 0 to disable rate limiting
RATE_LIMIT=100

# Backend Host header override (optional)
# If set, overrides the Host header sent to the backend
# BACKEND_HOST=api.internal.example.com

# ============================================
# LOGGING & MONITORING
# ============================================

# All requests are logged as JSON to stdout
# Example log line:
# {"timestamp":"2024-01-15T10:30:45.123456789Z","request_id":"1234567890","method":"GET","original_path":"/esim-proxy/users/123","normalized_path":"/v1/users/123","client_ip":"192.168.1.100","status":200,"latency_ms":150}

# Set environment for structured logging
# STRUCTURED_LOG=true (auto-set via JSON output)

# ============================================
# ADVANCED OPTIONS
# ============================================

# Request timeout (read/write/idle in seconds)
# These are hardcoded in the implementation:
# - Read timeout: 10s
# - Write timeout: 30s
# - Idle timeout: 60s

# ============================================
# EXAMPLE USAGE
# ============================================

# 1. With inline keys:
#    export BACKEND_URL=https://api.example.com
#    export API_KEYS=secret-prod-key,secret-staging-key
#    ./esim-proxy -mode=server

# 2. With key file:
#    echo "secret-prod-key" > /etc/esim-proxy/keys.txt
#    echo "secret-staging-key" >> /etc/esim-proxy/keys.txt
#    chmod 600 /etc/esim-proxy/keys.txt
#    export BACKEND_URL=https://api.example.com
#    export API_KEY_FILE=/etc/esim-proxy/keys.txt
#    ./esim-proxy -mode=server

# 3. In Docker:
#    docker run -e BACKEND_URL=https://api.example.com \
#               -e API_KEYS=key1,key2 \
#               -p 8080:8080 \
#               esim-proxy:latest

# 4. In Kubernetes:
#    kubectl create secret generic esim-keys --from-literal=keys="key1,key2"
#    kubectl apply -f deployment.yaml
